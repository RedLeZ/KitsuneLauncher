{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kitsune Launcher",
  "version": "0.1.0",
  "identifier": "com.kitsune.launcher",
  "build": {
    "beforeDevCommand": "cd ../ui && npm run dev",
    "beforeBuildCommand": "cd ../ui && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kitsune Launcher",
        "width": 1280,
        "height": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
